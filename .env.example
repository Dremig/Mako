# Required
OPENAI_API_KEY=sk-sMfM8fmnHTVbwVM9isDR2Ekl4eaul4G9B80Ny1sAO1klOrEc
# Optional: OpenAI-compatible base URL
OPENAI_BASE_URL=https://yunwu.ai/v1
# Optional API mode:
# - auto: use Responses API on official OpenAI hosts, chat/completions elsewhere
# - chat: force legacy chat/completions
# - responses: force Responses API
OPENAI_API_MODE=auto
# Optional models
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_AGENT_MODEL=gpt-5.2
# Optional reasoning effort for Responses API (`minimal|low|medium|high`)
OPENAI_REASONING_EFFORT=medium
# Optional (for custom gateways with self-signed cert)
OPENAI_INSECURE_TLS=0
# Optional HTTP resiliency tuning
# Total retries for API calls (default: 3)
OPENAI_HTTP_RETRIES=5
# Per-request timeout in seconds (default: 120)
OPENAI_HTTP_TIMEOUT_SEC=45
# Total retry budget window in seconds across all attempts (default: 45)
OPENAI_HTTP_RETRY_BUDGET_SEC=60
# Max backoff delay between retries in seconds (default: 6)
OPENAI_HTTP_RETRY_MAX_DELAY_SEC=8